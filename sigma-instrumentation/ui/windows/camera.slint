import { SigmaTheme } from "../theme.slint";
import { WindowFrame, Chip } from "common.slint";

export component CameraWindow inherits Rectangle {
    in property <bool> rear-view: true;
    in property <bool> front-available: true;
    in property <bool> rear-available: true;

    WindowFrame {
        width: 100%; height: 100%;
        title: "CAMERA";
        hint: root.rear-view ? "REAR" : "FRONT";

        Rectangle {
            vertical-stretch: 1;
            border-radius: 6px;
            background: SigmaTheme.camera-feed-bg;
            border-width: 1px;
            border-color: SigmaTheme.dial-rule;
            clip: true;

            for i in [0, 1, 2, 3, 4, 5, 6, 7]: Rectangle {
                x: 0; y: i * 44px + 12px; width: 100%; height: 1px;
                background: SigmaTheme.dial-whisper;
            }

            Text {
                width: 100%; height: 100%;
                text: root.rear-view ? "REAR CAMERA" : "FRONT CAMERA";
                color: SigmaTheme.dial-label;
                font-size: 26px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            Rectangle {
                x: 12px; y: 12px; width: 8px; height: 8px;
                border-radius: 4px; background: SigmaTheme.accent-red-dim;
            }
            Text { x: 26px; y: 10px; text: "REC"; color: SigmaTheme.dial-caption; font-size: 10px; font-weight: 600; }
        }

        HorizontalLayout {
            spacing: 8px;
            padding-top: 8px;
            Chip { text: "FRONT"; on: !root.rear-view && root.front-available; }
            Chip { text: "REAR"; on: root.rear-view && root.rear-available; }
            Rectangle { horizontal-stretch: 1; }
            Text {
                text: "SPACE snapshot · ↓ swap view";
                color: SigmaTheme.dial-caption;
                font-size: 10px;
                font-weight: 600;
                vertical-alignment: center;
            }
        }
    }
}
