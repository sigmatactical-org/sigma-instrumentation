import { SigmaTheme, SigmaTone } from "../theme.slint";

export component WindowFrame inherits Rectangle {
    in property <string> title;
    in property <string> hint;
    in property <bool> locked: false;

    background: transparent;
    border-width: 0px;
    clip: true;

    VerticalLayout {
        padding: 10px;
        spacing: 5px;

        HorizontalLayout {
            opacity: SigmaTone.title-opacity;
            Text {
                text: root.title;
                color: SigmaTheme.dial-whisper;
                font-family: "Operation Napalm";
                font-size: 13px;
                font-weight: 400;
                letter-spacing: 1.5px;
            }
            Rectangle { horizontal-stretch: 1; }
            if root.hint != "": Text {
                text: root.hint;
                color: SigmaTheme.dial-caption;
                font-size: 9px;
                font-weight: 400;
            }
        }
        Rectangle { height: 1px; background: SigmaTheme.dial-rule; opacity: SigmaTone.divider-opacity; }

        @children
    }
}

export component StatRow inherits HorizontalLayout {
    in property <string> label;
    in property <string> value;
    in property <color> value-color: SigmaTheme.dial-ink;
    in property <length> value-size: 22px;

    spacing: 6px;
    opacity: SigmaTone.stat-opacity;
    Text {
        text: root.label;
        color: SigmaTheme.dial-label;
        font-family: "Operation Napalm";
        font-size: 13px;
        font-weight: 400;
        letter-spacing: 0.5px;
        vertical-alignment: center;
    }
    Rectangle { horizontal-stretch: 1; }
    Text {
        text: root.value;
        color: root.value-color;
        font-size: root.value-size;
        font-weight: 400;
        vertical-alignment: center;
    }
}

export component MeterBar inherits Rectangle {
    in property <float> ratio: 0;
    in property <color> fill: SigmaTheme.dial-ink;

    height: 3px;
    border-radius: 1px;
    background: SigmaTheme.dial-whisper;
    opacity: SigmaTone.bar-opacity;

    Rectangle {
        x: 0; y: 0;
        width: parent.width * clamp(root.ratio, 0, 1);
        height: parent.height;
        border-radius: 1px;
        background: root.fill;
        opacity: SigmaTone.bar-fill-opacity;
    }
}

export component Chip inherits Rectangle {
    in property <string> text;
    in property <bool> on: false;
    in property <color> on-color: SigmaTheme.dial-ink;

    height: 18px;
    width: max(28px, inner.preferred-width);
    border-radius: 9px;
    opacity: root.on ? SigmaTone.chip-on-opacity : SigmaTone.chip-off-opacity;
    background: root.on ? root.on-color.with-alpha(0.08) : transparent;
    border-width: 1px;
    border-color: root.on ? root.on-color.with-alpha(0.22) : SigmaTheme.dial-whisper;

    inner := HorizontalLayout {
        x: 0; y: 0;
        padding-left: 7px;
        padding-right: 7px;
        height: 100%;
        alignment: center;
        Text {
            text: root.text;
            color: root.on ? SigmaTheme.dial-ink : SigmaTheme.dial-label;
            font-family: "Operation Napalm";
            font-size: 12px;
            font-weight: 400;
            letter-spacing: 0.3px;
            vertical-alignment: center;
        }
    }
}

/// Bordered panel control — same chrome as Security status boxes.
export component PanelAction inherits TouchArea {
    in property <string> label;
    in property <bool> active: true;
    in property <bool> emphasis: false;
    callback activated();

    height: 36px;
    enabled: root.active;
    clicked => { if root.active { root.activated(); } }

    Rectangle {
        width: 100%; height: 100%;
        border-radius: 6px;
        background: transparent;
        border-width: 1px;
        border-color: !root.active ? SigmaTheme.dial-whisper
            : (root.emphasis ? SigmaTheme.accent-amber : SigmaTheme.dial-rule);
        opacity: root.active
            ? (root.pressed ? SigmaTone.content-opacity : SigmaTone.stat-opacity)
            : SigmaTone.chip-off-opacity;

        Text {
            width: 100%; height: 100%;
            text: root.label;
            color: !root.active ? SigmaTheme.dial-caption
                : (root.emphasis ? SigmaTheme.dial-value : SigmaTheme.dial-ink);
            font-family: "Operation Napalm";
            font-size: 13px;
            font-weight: 400;
            letter-spacing: 0.5px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}
