import { SigmaTheme, SigmaTone } from "theme.slint";
import { RpmDial, Tick } from "widgets/rpm_dial.slint";
import { SpeedReadout } from "widgets/speed_readout.slint";
import { SystemsWindow } from "windows/systems.slint";
import { NavigationWindow } from "windows/navigation.slint";
import { CompassWindow } from "windows/compass_gps.slint";
import { DiagnosticsWindow } from "windows/diagnostics.slint";
import { ConnectivityWindow } from "windows/connectivity.slint";
import { CameraWindow } from "windows/camera.slint";
import { MaintenanceWindow } from "windows/maintenance.slint";
import { FuelWindow } from "windows/fuel.slint";
import { SecurityWindow } from "windows/security.slint";

// Window index table — keep in sync with src/main.rs and app.slint (keys 1–9).
//   0 Systems   1 Navigation   2 Compass/GPS   3 Diagnostics
//   4 Connectivity   5 Camera   6 Maintenance   7 Fuel   8 Security
// Indices 0–3: left panel while riding. 4–8: full-screen when stopped.

component FullScreenHost inherits Rectangle {
    in property <int> active-window: 0;
    in property <float> fuel-pct: 0.62;

    width: 100%;
    height: 100%;
    background: transparent;

    if root.active-window == 4: ConnectivityWindow {
        width: 100%; height: 100%;
    }
    if root.active-window == 5: CameraWindow {
        width: 100%; height: 100%;
    }
    if root.active-window == 6: MaintenanceWindow {
        width: 100%; height: 100%;
    }
    if root.active-window == 7: FuelWindow {
        width: 100%; height: 100%;
        fuel-pct: root.fuel-pct;
    }
    if root.active-window == 8: SecurityWindow {
        width: 100%; height: 100%;
    }
}

export component RoadDashboard inherits Rectangle {
    in property <float> rpm: 1200;
    in property <int> speed: 0;
    in property <int> gear: 0;
    in property <bool> at-redline: false;
    in property <bool> side-stand: true;
    in property <string> riding-mode: "SPORT";

    in property <string> track-path;
    in property <string> redline-path;
    in property <string> swept-path;
    in property <string> ticks-major;
    in property <string> ticks-minor;
    in property <string> ticks-redline;
    in property <string> needle-left;
    in property <string> needle-spine;
    in property <string> needle-right;
    in property <string> needle-outline;
    in property <[Tick]> labels;

    in property <string> d-hundreds;
    in property <string> d-tens;
    in property <string> d-ones;

    in property <int> current-window: 0;
    in property <bool> nav-blocked-hint: false;

    in property <string> clock: "14:32";
    in property <float> fuel-pct: 0.62;
    in property <int> coolant-c: 84;
    in property <int> oil-c: 96;
    in property <int> odometer: 1245;
    in property <float> trip1: 137.4;
    in property <float> trip2: 42.1;
    in property <float> lean-angle: 0;
    in property <float> gforce: 0;
    in property <float> battery-v: 13.9;
    in property <int> can-load: 22;
    in property <int> dtc: 0;
    in property <float> heading: 45;
    in property <string> heading-label: "NE";
    in property <int> elevation: 667;

    property <bool> stopped: root.speed == 0;
    property <bool> show-fullscreen: root.stopped && root.current-window >= 4;
    property <int> panel-window: root.current-window <= 3 ? root.current-window : 0;
    property <bool> speed-hot: root.speed >= 200;

    background: SigmaTheme.tft;

    if !root.show-fullscreen: Rectangle {
        width: 800px;
        height: 480px;

        RpmDial {
            x: 0;
            y: 0;
            rpm: root.rpm;
            gear: root.gear;
            at-redline: root.at-redline;
            track-path: root.track-path;
            redline-path: root.redline-path;
            swept-path: root.swept-path;
            ticks-major: root.ticks-major;
            ticks-minor: root.ticks-minor;
            ticks-redline: root.ticks-redline;
            needle-left: root.needle-left;
            needle-spine: root.needle-spine;
            needle-right: root.needle-right;
            needle-outline: root.needle-outline;
            labels: root.labels;
        }

        // Speed — centred above dial hub, inside upper face (design coords)
        SpeedReadout {
            x: 452px - self.width / 2;
            y: 52px;
            d-hundreds: root.d-hundreds;
            d-tens: root.d-tens;
            d-ones: root.d-ones;
            hot: root.speed-hot;
        }

        // left panel — top/bottom aligned with dial bezel (centre 246, r 214)
        Rectangle {
            x: 8px; y: 32px; width: 226px; height: 428px;

            if root.panel-window == 0: SystemsWindow {
                width: 100%; height: 100%;
                clock: root.clock;
                fuel-pct: root.fuel-pct;
                coolant-c: root.coolant-c;
                oil-c: root.oil-c;
                odometer: root.odometer;
                trip1: root.trip1;
                trip2: root.trip2;
                lean-angle: root.lean-angle;
                gforce: root.gforce;
                riding-mode: root.riding-mode;
            }
            if root.panel-window == 1: NavigationWindow {
                width: 100%; height: 100%;
            }
            if root.panel-window == 2: CompassWindow {
                width: 100%; height: 100%;
                heading: root.heading;
                heading-label: root.heading-label;
                elevation: root.elevation;
            }
            if root.panel-window == 3: DiagnosticsWindow {
                width: 100%; height: 100%;
                rpm: root.rpm;
                coolant-c: root.coolant-c;
                oil-c: root.oil-c;
                battery-v: root.battery-v;
                can-load: root.can-load;
                dtc: root.dtc;
            }
        }

        if root.side-stand: Rectangle {
            x: 302px; y: 200px; width: 300px; height: 80px;
            opacity: SigmaTone.side-stand-opacity;
            background: transparent;
            border-width: 1px;
            border-color: SigmaTheme.dial-rule;
            border-radius: 6px;
            Text {
                width: 100%; height: 100%;
                text: "SIDE STAND";
                font-size: 22px;
                font-weight: 700;
                color: SigmaTheme.dial-ink;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        if root.nav-blocked-hint && !root.stopped: Rectangle {
            x: parent.width / 2 - self.width / 2;
            y: parent.height - 36px;
            width: toast.preferred-width + 24px;
            height: 22px;
            opacity: SigmaTone.toast-opacity;
            background: transparent;
            border-radius: 4px;
            border-width: 1px;
            border-color: SigmaTheme.dial-rule;
            toast := Text {
                x: 12px; y: 0; height: 100%;
                text: "Stop to open full-screen windows";
                color: SigmaTheme.dial-caption;
                font-size: 9px;
                font-weight: 600;
                vertical-alignment: center;
            }
        }

        Text {
            x: 12px; y: parent.height - 2px - self.preferred-height;
            text: root.stopped ? "← → window   ↑ home   +/- demo" : "← → window   +/- demo";
            color: SigmaTheme.dial-whisper;
            font-size: 8px;
            font-weight: 600;
            opacity: SigmaTone.hint-opacity;
        }
    }

    if root.show-fullscreen: Rectangle {
        x: 8px; y: 8px;
        width: parent.width - 16px;
        height: parent.height - 16px;
        FullScreenHost {
            width: 100%; height: 100%;
            active-window: root.current-window;
            fuel-pct: root.fuel-pct;
        }
    }

    if root.show-fullscreen: Text {
        x: 16px; y: parent.height - 4px - self.preferred-height;
        text: "← → switch window   ↑ back to ride";
        color: SigmaTheme.dial-whisper;
        font-size: 8px;
        font-weight: 600;
        opacity: SigmaTone.hint-opacity;
    }
}
