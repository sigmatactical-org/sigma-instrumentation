import { SigmaTheme, SigmaTone } from "theme.slint";
import { RpmDial, Tick } from "widgets/rpm_dial.slint";
import { SystemsWindow } from "windows/systems.slint";
import { NavigationWindow } from "windows/navigation.slint";
import { CompassWindow } from "windows/compass_gps.slint";
import { DiagnosticsWindow } from "windows/diagnostics.slint";
import { ConnectivityWindow, ConnItem } from "windows/connectivity.slint";
import { CameraWindow } from "windows/camera.slint";
import { MaintenanceWindow } from "windows/maintenance.slint";
import { FuelWindow } from "windows/fuel.slint";
import { SecurityWindow } from "windows/security.slint";
import { UpdatesWindow } from "windows/updates.slint";

// Window index table — keep in sync with windows/mod.rs and app.slint.
//   0 Systems   1 Navigation   2 Compass/GPS   3 Diagnostics
//   4 Connectivity   5 Camera   6 Maintenance   7 Fuel   8 Security   9 Updates
// Indices 0–3: left panel while riding. 4–9: full-screen when stopped.

component FullScreenHost inherits Rectangle {
    in property <int> active-window: 0;
    in property <float> fuel-pct: 0.62;
    in property <string> update-channel: "dev";
    in property <string> update-current-version: "0.0.0";
    in property <string> update-available-version: "";
    in property <string> update-notes: "";
    in property <bool> update-available: false;
    in property <bool> update-busy: false;
    in property <string> update-status: "";
    in property <int> update-focus: 0;
    callback check-updates();
    callback install-updates();

    in property <int> conn-screen: 0;
    in property <[ConnItem]> conn-items;
    in property <string> conn-status: "";
    in property <bool> conn-busy: false;
    in property <bool> bt-powered: false;
    in property <bool> bt-connected: false;
    in property <string> bt-device: "—";
    in property <int> bt-battery: -1;
    in property <bool> wifi-powered: false;
    in property <bool> wifi-connected: false;
    in property <string> wifi-ssid: "—";

    width: 100%;
    height: 100%;
    background: transparent;

    if root.active-window == 4: ConnectivityWindow {
        width: 100%; height: 100%;
        conn-screen: root.conn-screen;
        conn-items: root.conn-items;
        conn-status: root.conn-status;
        conn-busy: root.conn-busy;
        bt-powered: root.bt-powered;
        bt-connected: root.bt-connected;
        bt-device: root.bt-device;
        bt-battery: root.bt-battery;
        wifi-powered: root.wifi-powered;
        wifi-connected: root.wifi-connected;
        wifi-ssid: root.wifi-ssid;
    }
    if root.active-window == 5: CameraWindow {
        width: 100%; height: 100%;
    }
    if root.active-window == 6: MaintenanceWindow {
        width: 100%; height: 100%;
    }
    if root.active-window == 7: FuelWindow {
        width: 100%; height: 100%;
        fuel-pct: root.fuel-pct;
    }
    if root.active-window == 8: SecurityWindow {
        width: 100%; height: 100%;
    }
    if root.active-window == 9: UpdatesWindow {
        width: 100%; height: 100%;
        channel: root.update-channel;
        current-version: root.update-current-version;
        available-version: root.update-available-version;
        update-notes: root.update-notes;
        update-available: root.update-available;
        update-busy: root.update-busy;
        update-status: root.update-status;
        update-focus: root.update-focus;
        check-updates => { root.check-updates(); }
        install-updates => { root.install-updates(); }
    }
}

export component RoadDashboard inherits Rectangle {
    in property <float> rpm: 1200;
    in property <int> speed: 0;
    in property <int> gear: 0;
    in property <string> gear-label: "N";
    in property <bool> at-redline: false;
    in property <bool> side-stand: true;
    in property <string> riding-mode: "SPORT";
    in property <bool> turn-left: false;
    in property <bool> turn-right: false;
    in property <bool> signal-lit: false;
    in property <string> signal-left-path;
    in property <string> signal-right-path;

    in property <string> track-path;
    in property <string> redline-path;
    in property <string> swept-path;
    in property <string> ticks-major;
    in property <string> ticks-minor;
    in property <string> ticks-redline;
    in property <string> needle-left;
    in property <string> needle-spine;
    in property <string> needle-right;
    in property <string> needle-outline;
    in property <[Tick]> labels;
    in property <string> rpm-scale-caption: "RPM × 1000";

    in property <string> d-hundreds: "";
    in property <string> d-tens: "";
    in property <string> d-ones: "0";

    in property <int> current-window: 0;
    in property <bool> nav-blocked-hint: false;

    in property <string> clock: "14:32";
    in property <float> fuel-pct: 0.62;
    in property <int> coolant-c: 84;
    in property <int> oil-c: 96;
    in property <int> odometer: 1245;
    in property <float> trip1: 137.4;
    in property <float> trip2: 42.1;
    in property <float> lean-angle: 0;
    in property <float> gforce: 0;
    in property <float> battery-v: 13.9;
    in property <int> can-load: 22;
    in property <int> dtc: 0;
    in property <bool> abs-active: false;
    in property <bool> tc-active: false;
    in property <float> heading: 45;
    in property <string> heading-label: "NE";
    in property <int> elevation: 667;
    in property <bool> telemetry-live: true;

    in property <string> update-channel: "dev";
    in property <string> update-current-version: "0.0.0";
    in property <string> update-available-version: "";
    in property <string> update-notes: "";
    in property <bool> update-available: false;
    in property <bool> update-busy: false;
    in property <string> update-status: "";
    in property <int> update-focus: 0;
    callback check-updates();
    callback install-updates();

    in property <int> conn-screen: 0;
    in property <[ConnItem]> conn-items;
    in property <string> conn-status: "";
    in property <bool> conn-busy: false;
    in property <bool> bt-powered: false;
    in property <bool> bt-connected: false;
    in property <string> bt-device: "—";
    in property <int> bt-battery: -1;
    in property <bool> wifi-powered: false;
    in property <bool> wifi-connected: false;
    in property <string> wifi-ssid: "—";

    property <bool> stopped: root.speed == 0;
    property <bool> show-fullscreen: root.stopped && root.current-window >= 4;
    property <int> panel-window: root.current-window <= 3 ? root.current-window : 0;
    // Bottom-right — other system messages (side stand is on the gear hub)
    property <string> system-message:
        root.update-available ? "UPDATE AVAILABLE"
        : (root.nav-blocked-hint && !root.stopped ? "Stop to open full-screen windows" : "");

    background: SigmaTheme.tft;

    if !root.show-fullscreen: Rectangle {
        width: 800px;
        height: 480px;

        RpmDial {
            x: 0;
            y: 0;
            rpm: root.rpm;
            gear: root.gear;
            gear-label: root.gear-label;
            at-redline: root.at-redline;
            track-path: root.track-path;
            redline-path: root.redline-path;
            swept-path: root.swept-path;
            ticks-major: root.ticks-major;
            ticks-minor: root.ticks-minor;
            ticks-redline: root.ticks-redline;
            needle-left: root.needle-left;
            needle-spine: root.needle-spine;
            needle-right: root.needle-right;
            needle-outline: root.needle-outline;
            labels: root.labels;
            rpm-scale-caption: root.rpm-scale-caption;
            signal-left-path: root.signal-left-path;
            signal-right-path: root.signal-right-path;
            turn-left: root.turn-left;
            turn-right: root.turn-right;
            signal-lit: root.signal-lit;
        }

        // left panel — top/bottom aligned with dial bezel (centre 246, r 214)
        Rectangle {
            x: 8px; y: 32px; width: 226px; height: 428px;

            if root.panel-window == 0: SystemsWindow {
                width: 100%; height: 100%;
                clock: root.clock;
                fuel-pct: root.fuel-pct;
                coolant-c: root.coolant-c;
                oil-c: root.oil-c;
                odometer: root.odometer;
                trip1: root.trip1;
                trip2: root.trip2;
                lean-angle: root.lean-angle;
                gforce: root.gforce;
                riding-mode: root.riding-mode;
            }
            if root.panel-window == 1: NavigationWindow {
                width: 100%; height: 100%;
            }
            if root.panel-window == 2: CompassWindow {
                width: 100%; height: 100%;
                heading: root.heading;
                heading-label: root.heading-label;
                elevation: root.elevation;
                lean-angle: root.lean-angle;
                gforce: root.gforce;
            }
            if root.panel-window == 3: DiagnosticsWindow {
                width: 100%; height: 100%;
                rpm: root.rpm;
                coolant-c: root.coolant-c;
                oil-c: root.oil-c;
                battery-v: root.battery-v;
                can-load: root.can-load;
                dtc: root.dtc;
                abs-active: root.abs-active;
                tc-active: root.tc-active;
            }
        }

        Text {
            x: 12px; y: parent.height - 2px - self.preferred-height;
            text: root.stopped ? "← → window   ↑ home   +/- demo" : "← → window   +/- demo";
            color: SigmaTheme.dial-whisper;
            font-size: 8px;
            font-weight: 400;
            opacity: SigmaTone.hint-opacity;
        }

        // TOP-RIGHT speed — outside the dial (match gear hub weight/size)
        Text {
            x: 540px;
            y: 4px;
            width: 220px;
            height: 86px;
            text: root.d-hundreds + root.d-tens + root.d-ones;
            color: #ffffff;
            font-size: 74px;
            font-weight: 800;
            horizontal-alignment: right;
            vertical-alignment: center;
        }
        Text {
            x: 764px;
            y: 68px;
            width: 28px;
            text: "km/h";
            color: #c8c8d0;
            font-family: "Operation Napalm";
            font-size: 14px;
            font-weight: 400;
        }

        // SIDE STAND — bold, drawn over the gear hub
        if root.side-stand: Rectangle {
            x: 452px - 150px;
            y: 246px - 28px;
            width: 300px;
            height: 56px;
            background: #000000cc;
            border-radius: 4px;
            Text {
                width: 100%;
                height: 100%;
                text: "SIDE STAND";
                color: #ffffff;
                font-family: "DejaVu Sans";
                font-size: 28px;
                font-weight: 800;
                letter-spacing: 2px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        // BOTTOM-RIGHT — other system messages (not side stand)
        if root.system-message != "": Rectangle {
            x: 560px;
            y: 400px;
            width: 228px;
            height: 64px;
            background: transparent;
            Text {
                width: 100%;
                height: 100%;
                text: root.system-message;
                color: SigmaTheme.dial-ink;
                font-family: "Operation Napalm";
                font-size: 18px;
                font-weight: 400;
                letter-spacing: 1px;
                horizontal-alignment: right;
                vertical-alignment: center;
                wrap: word-wrap;
            }
        }
    }

    if root.show-fullscreen: Rectangle {
        x: 8px; y: 8px;
        width: parent.width - 16px;
        height: parent.height - 16px;
        FullScreenHost {
            width: 100%; height: 100%;
            active-window: root.current-window;
            fuel-pct: root.fuel-pct;
            update-channel: root.update-channel;
            update-current-version: root.update-current-version;
            update-available-version: root.update-available-version;
            update-notes: root.update-notes;
            update-available: root.update-available;
            update-busy: root.update-busy;
            update-status: root.update-status;
            update-focus: root.update-focus;
            check-updates => { root.check-updates(); }
            install-updates => { root.install-updates(); }
            conn-screen: root.conn-screen;
            conn-items: root.conn-items;
            conn-status: root.conn-status;
            conn-busy: root.conn-busy;
            bt-powered: root.bt-powered;
            bt-connected: root.bt-connected;
            bt-device: root.bt-device;
            bt-battery: root.bt-battery;
            wifi-powered: root.wifi-powered;
            wifi-connected: root.wifi-connected;
            wifi-ssid: root.wifi-ssid;
        }
    }

    if root.show-fullscreen: Text {
        x: 16px; y: parent.height - 4px - self.preferred-height;
        text: "← → prev/next   ↑ back   ↓ select";
        color: SigmaTheme.dial-whisper;
        font-size: 8px;
        font-weight: 400;
        opacity: SigmaTone.hint-opacity;
    }
}
