import { SigmaTheme } from "../theme.slint";

export struct Tick {
    x: float,
    y: float,
    label: string,
    redline: bool,
}

component GaugePath inherits Path {
    width: 800px;
    height: 480px;
    viewbox-x: 0;
    viewbox-y: 0;
    viewbox-width: 800;
    viewbox-height: 480;
    fill: transparent;
}

// RPM dial — fixed 800×480 design canvas (must match gauge.rs CX/CY/R).
export component RpmDial inherits Rectangle {
    in property <float> rpm: 0;
    in property <int> gear: 0;
    // String form — FemtoVG leaves `\{int}` blank; "N"/digits must be real strings.
    in property <string> gear-label: "N";
    in property <bool> at-redline: false;

    in property <string> track-path;
    in property <string> redline-path;
    in property <string> swept-path;
    in property <string> ticks-major;
    in property <string> ticks-minor;
    in property <string> ticks-redline;
    in property <string> needle-left;
    in property <string> needle-spine;
    in property <string> needle-right;
    in property <string> needle-outline;
    in property <[Tick]> labels;
    in property <string> rpm-scale-caption: "RPM × 1000";

    // Turn / hazard — 30° outer-ring sectors at 9 o'clock / 3 o'clock
    in property <string> signal-left-path;
    in property <string> signal-right-path;
    in property <bool> turn-left: false;
    in property <bool> turn-right: false;
    in property <bool> signal-lit: false;

    width: 800px;
    height: 480px;
    background: transparent;

    Rectangle {
        x: 452px - 214px; y: 246px - 214px; width: 428px; height: 428px;
        border-radius: 214px; background: SigmaTheme.dial-bezel;
        border-width: 2px; border-color: SigmaTheme.dial-bezel-border;
    }
    Rectangle {
        x: 452px - 202px; y: 246px - 202px; width: 404px; height: 404px;
        border-radius: 202px; background: SigmaTheme.dial-face-bg;
    }

    // Turn / hazard indicators sit on the outer ring (under ticks/needle)
    if root.turn-left && root.signal-lit: Path {
        width: 800px; height: 480px;
        viewbox-x: 0; viewbox-y: 0; viewbox-width: 800; viewbox-height: 480;
        commands: root.signal-left-path;
        fill: SigmaTheme.signal-amber;
    }
    if root.turn-right && root.signal-lit: Path {
        width: 800px; height: 480px;
        viewbox-x: 0; viewbox-y: 0; viewbox-width: 800; viewbox-height: 480;
        commands: root.signal-right-path;
        fill: SigmaTheme.signal-amber;
    }
    // Dim resting glow while signalling but in the off half of the blink
    if root.turn-left && !root.signal-lit: Path {
        width: 800px; height: 480px;
        viewbox-x: 0; viewbox-y: 0; viewbox-width: 800; viewbox-height: 480;
        commands: root.signal-left-path;
        fill: SigmaTheme.signal-amber-dim;
    }
    if root.turn-right && !root.signal-lit: Path {
        width: 800px; height: 480px;
        viewbox-x: 0; viewbox-y: 0; viewbox-width: 800; viewbox-height: 480;
        commands: root.signal-right-path;
        fill: SigmaTheme.signal-amber-dim;
    }

    Path {
        width: 800px; height: 480px;
        viewbox-x: 0; viewbox-y: 0; viewbox-width: 800; viewbox-height: 480;
        commands: root.swept-path;
        fill: root.at-redline ? SigmaTheme.redline-bright : SigmaTheme.dial-swept;
        opacity: root.at-redline ? 0.42 : 0.28;
    }

    GaugePath { commands: root.track-path; stroke: SigmaTheme.dial-track; stroke-width: 2px; }
    GaugePath {
        commands: root.redline-path;
        stroke: root.at-redline ? SigmaTheme.redline-bright : SigmaTheme.accent-red-dim;
        stroke-width: 8px;
    }
    GaugePath { commands: root.ticks-minor; stroke: SigmaTheme.dial-tick-minor; stroke-width: 1.5px; }
    GaugePath { commands: root.ticks-major; stroke: SigmaTheme.dial-tick-major; stroke-width: 3.5px; }
    GaugePath {
        commands: root.ticks-redline;
        stroke: root.at-redline ? SigmaTheme.redline-bright : SigmaTheme.accent-red;
        stroke-width: 3.5px;
    }

    GaugePath {
        commands: root.needle-left;
        fill: root.at-redline ? SigmaTheme.redline-bright : SigmaTheme.needle-left;
    }
    GaugePath {
        commands: root.needle-right;
        fill: root.at-redline ? SigmaTheme.redline-bright-dim : SigmaTheme.needle-right;
    }
    GaugePath {
        commands: root.needle-spine;
        fill: root.at-redline ? SigmaTheme.redline-needle-tip : SigmaTheme.needle-spine;
    }
    GaugePath {
        commands: root.needle-outline;
        stroke: SigmaTheme.needle-outline;
        stroke-width: 2px;
    }

    Rectangle {
        x: 452px - 58px; y: 246px - 58px; width: 116px; height: 116px;
        border-radius: 58px; background: SigmaTheme.dial-face-bg;
        border-width: 4px; border-color: SigmaTheme.dial-gear-ring;
        Text {
            width: 100%;
            height: 100%;
            text: root.gear-label;
            color: root.gear == 0 ? #4ade80 : #ffffff;
            font-size: 74px;
            font-weight: 800;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    Text {
        width: 120px;
        x: 452px - 60px;
        y: 246px + 74px;
        text: root.rpm-scale-caption;
        color: SigmaTheme.dial-caption;
        font-family: "Operation Napalm";
        font-size: 16px;
        font-weight: 400;
        horizontal-alignment: center;
    }

    // Sigma mark on the lower face, below the scale caption. Path data is the
    // brand symbol from design-resources/sigma.svg; the viewbox is cropped to
    // the glyph's own bounds (x -2.81..88, y 10..90) so the box below is the
    // drawn size, not the artboard.
    Path {
        x: 452px - 17px;
        y: 246px + 100px;
        width: 34px;
        height: 30px;
        viewbox-x: -2.81;
        viewbox-y: 10;
        viewbox-width: 90.81;
        viewbox-height: 80;
        commands: "M88.00 10.00 L -2.81 10.00 L 47.19 50.00 L -2.81 90.00 L 88.00 90.00 L 88.00 74.00 L 87.66 72.07 L 87.11 70.29 L 86.36 68.68 L 85.40 67.22 L 84.23 65.93 L 82.86 64.79 L 81.28 63.82 L 79.50 63.00 L 71.00 74.00 L 42.81 74.00 L 72.81 50.00 L 42.81 26.00 L 71.00 26.00 L 79.50 37.00 L 81.28 36.18 L 82.86 35.21 L 84.23 34.07 L 85.40 32.77 L 86.36 31.32 L 87.11 29.71 L 87.66 27.93 L 88.00 26.00 Z";
        fill: SigmaTheme.dial-label;
    }

    // RPM scale numerals — drawn last so nothing covers them
    for t in root.labels: Text {
        x: (t.x - 18) * 1px;
        y: (t.y - 15) * 1px;
        width: 40px;
        height: 36px;
        text: t.label;
        color: t.redline
            ? (root.at-redline ? SigmaTheme.redline-bright : #ff8a80)
            : #ffffff;
        font-family: "DejaVu Sans";
        font-size: 26px;
        font-weight: 400;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}
