import { SigmaTheme } from "../theme.slint";

// Full-screen boot branding — first frame from sigma-dash until dashboard is ready.
export component BootSplash inherits Rectangle {
    width: 100%;
    height: 100%;
    background: SigmaTheme.bg;

    Text {
        text: "Σ";
        color: SigmaTheme.accent-red;
        font-size: 120px;
        font-weight: 800;
        x: (parent.width - self.preferred-width) / 2;
        y: parent.height * 0.30;
    }

    Text {
        text: "SIGMA";
        color: SigmaTheme.dial-value;
        font-size: 36px;
        font-weight: 700;
        letter-spacing: 8px;
        x: (parent.width - self.preferred-width) / 2;
        y: parent.height * 0.30 + 128px;
    }

    Text {
        text: "Instrument Cluster";
        color: SigmaTheme.dial-caption;
        font-size: 12px;
        font-weight: 600;
        x: (parent.width - self.preferred-width) / 2;
        y: parent.height * 0.30 + 172px;
    }
}
